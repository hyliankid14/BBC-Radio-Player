<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext HTTP for BBC podcast CDN redirects.
         BBC's mediaselector redirects to Triton Digital over plain HTTP. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">bbci.co.uk</domain>
        <domain includeSubdomains="true">bbc.co.uk</domain>
        <domain includeSubdomains="true">tritondigital.com</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
