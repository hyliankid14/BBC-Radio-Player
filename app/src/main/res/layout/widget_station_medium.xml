<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_artwork"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/widget_station_artwork"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_station_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_now_playing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/widget_play_pause"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_control_background"
            android:contentDescription="@string/widget_play_pause"
            android:padding="8dp"
            android:src="@drawable/ic_play_arrow"
            android:tint="@color/md_theme_onPrimaryContainer" />

        <ImageView
            android:id="@+id/widget_stop"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
